      "Enabled": true,
      "MaxRoundsPerSprint": 50,
      "MaxRoundsPerStage": 20,
      "MaxConsecutiveSelfDriveContinuations": 8,
      "MinIntervalBetweenContinuationsMs": 2000
    }
  },
  "AllowedHosts": "*"
